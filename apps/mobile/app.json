{
  "slug": "gasolina",
  "version": "1.0.1",
  "orientation": "portrait",
  "userInterfaceStyle": "automatic",
  "updates": {
    "fallbackToCacheTimeout": 0
  },
  "assetBundlePatterns": [
    "**/*"
  ],
  "android": {
    "allowBackup": false,
    "permissions": [
      "ACCESS_COARSE_LOCATION",
      "ACCESS_FINE_LOCATION"
    ]
  },
  "ios": {
    "supportsTablet": true,
    "infoPlist": {
      "NSLocationWhenInUseUsageDescription": "Usamos sua localização para mostrar os postos mais próximos de você."
    }
  },
  "web": {
    "bundler": "metro"
  },
  "plugins": [
    "expo-localization",
    "expo-font",
    [
      "react-native-edge-to-edge",
      {
        "android": {
          "parentTheme": "Light",
          "enforceNavigationBarContrast": false
        }
      }
    ],
    "expo-build-properties",
    "expo-router",
    [
      "expo-location",
      {
        "locationWhenInUsePermission": "Usamos sua localização para mostrar os postos mais próximos de você."
      }
    ]
  ],
  "experiments": {
    "tsconfigPaths": true,
    "typedRoutes": true
  },
  "extra": {
    "ignite": {
      "version": "11.5.0"
    },
    "router": {},
    "eas": {}
  },
  "owner": "matheudsp"
}