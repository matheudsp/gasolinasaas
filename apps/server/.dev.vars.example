# Local development environment variables for Wrangler
# This file is automatically loaded by `wrangler dev`
# Copy this file to .dev.vars and fill in your actual values

NODE_ENV=development
CORS_ORIGIN=

# [Database]
DATABASE_URL=
DATABASE_URL_POOLER=


# [Better Auth]
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api.gasolina.cloud

# [Google OAuth]
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [AWS]
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
